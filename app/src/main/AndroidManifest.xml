<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Permiso para usar internet, necesario para Retrofit y Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Permiso para obtener la ubicacion aproximada con el WiFi o la red -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Permiso para mostrar notificaciones en Android 13 o superior -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Gearchfrontend"
        android:usesCleartextTraffic="true">

        <!-- Servicio de Firebase que recibe las notificaciones push -->
        <service
            android:name=".GearchFirebaseService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <activity
            android:name=".PerfilAdminActivity"
            android:exported="false" />
        <activity
            android:name=".AnadirHorarioActivity"
            android:exported="false" />
        <activity
            android:name=".AnadirServicioActivity"
            android:exported="false" />
        <activity
            android:name=".PerfilActivity"
            android:exported="false" />
        <activity
            android:name=".ResenaDetalleActivity"
            android:exported="false" />
        <activity
            android:name=".EditarTallerActivity"
            android:exported="false" />
        <activity
            android:name=".ResenasAdminActivity"
            android:exported="false" />
        <activity
            android:name=".HorarioAdminActivity"
            android:exported="false" />
        <activity
            android:name=".ServiciosAdminActivity"
            android:exported="false" />
        <activity
            android:name=".CitasAdminActivity"
            android:exported="false" />
        <activity
            android:name=".BuscarActivity"
            android:exported="false" />
        <activity
            android:name=".EscribirResenaActivity"
            android:exported="false" />
        <activity
            android:name=".AnadirVehiculoActivity"
            android:exported="false" />
        <activity
            android:name=".MisVehiculosActivity"
            android:exported="false" />
        <activity
            android:name=".MisCitasActivity"
            android:exported="false" />
        <activity
            android:name=".DetalleTallerActivity"
            android:exported="false" />
        <activity
            android:name=".ReservarActivity"
            android:exported="false" />
        <activity
            android:name=".MainClienteActivity"
            android:exported="false" />
        <activity
            android:name=".MainAdminActivity"
            android:exported="false" />
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>